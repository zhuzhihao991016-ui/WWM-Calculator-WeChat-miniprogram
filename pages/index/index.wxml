<view wx:if="{{showSharePoster}}" class="share-poster-mask" catchtouchmove="noop">
  <view class="share-poster-popup">
    <view class="share-poster-title">分享图片</view>
    <image class="share-poster-image" src="{{sharePosterPath}}" mode="widthFix" bindtap="previewSharePoster"></image>
    <view class="share-poster-actions">
      <button class="share-poster-secondary" bindtap="closeSharePoster">关闭</button>
      <button class="share-poster-primary" bindtap="saveSharePoster">保存图片</button>
    </view>
  </view>
</view>

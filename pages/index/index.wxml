<view wx:if="{{ui.currentTab === 'panel'}}" class="container">
  <view class="page-title">国际服全流派毕业度计算器</view>
  <view class="data-source-banner {{dataSourceInfo.isLocalOnly ? 'data-source-banner-local' : ''}}">
    <text class="data-source-banner-label">{{dataSourceInfo.label}}</text>
    <text class="data-source-banner-meta" wx:if="{{dataSourceInfo.envVersion}}">{{dataSourceInfo.envVersion}}</text>
  </view>

  <!-- ===== 面板页 ===== -->
  <view wx:if="{{ui.currentTab === 'panel'}}">
  <!-- 顶部结果：仅展示轴结果 -->
  <view class="card result-card" wx:if="{{axisResult}}">
    <view class="result-top">
      <view class="result-title">轴期望总伤害</view>
      <view class="result-number">{{axisResult.totalExpectedDamage}}</view>
      <view class="result-sub">
        {{axisResult.schoolName}} / {{axisResult.axisName}} / {{currentTarget.targetName}}
      </view>
    </view>

    <view class="result-tag-list">
      <text class="result-tag">时长：{{axisResult.duration}} 秒</text>
      <text class="result-tag">实际秒伤：{{axisResult.dps}}</text>
      <text class="result-tag">毕业秒伤：{{axisResult.graduateDps}}</text>
      <text class="result-tag">毕业率：{{axisResult.graduateRate}}</text>
    </view>

    <view class="expand-btn" bindtap="toggleResultDetail">
      {{ui.showResultDetail ? '收起轴详细结果' : '展开轴详细结果'}}
    </view>
    <view class="expand-btn result-equipment-link" bindtap="navigateToEquipment">
      去装备库校准 / 遍历搭配
    </view>

    <view class="detail-panel" wx:if="{{ui.showResultDetail}}">

      <view class="detail-title">技能伤害构成</view>
<view class="summary-list">
  <block wx:for="{{axisResult.skillSummaryList}}" wx:for-item="sk" wx:for-index="idx" wx:key="idx">
    <view class="summary-item skill-summary-item">
      <text class="summary-label skill-summary-label">{{sk.skillName}}</text>
      <text class="summary-value skill-summary-value">{{sk.totalDamage}}（{{sk.ratio}}）</text>
    </view>
  </block>
</view>

<view class="detail-title" style="margin-top:16rpx;">命中类型占比</view>
<view class="summary-list">
  <view class="summary-item">
    <text class="summary-label">擦伤</text>
    <text class="summary-value">{{axisResult.hitTypeStats.glancingRate}}</text>
  </view>
  <view class="summary-item">
    <text class="summary-label">普通（白字）</text>
    <text class="summary-value">{{axisResult.hitTypeStats.normalRate}}</text>
  </view>
  <view class="summary-item">
    <text class="summary-label">会心</text>
    <text class="summary-value">{{axisResult.hitTypeStats.insightRate}}</text>
  </view>
  <view class="summary-item">
    <text class="summary-label">会意</text>
    <text class="summary-value">{{axisResult.hitTypeStats.perfectRate}}</text>
  </view>
</view>

</view>
  </view>

  <!-- 无轴数据时提示 -->
  <view class="card result-card" wx:elif="{{currentAxis === null}}">
    <view class="tip">当前流派暂无轴数据，请选择其他流派</view>
  </view>

  <!-- 当前配置 -->
  <view class="card">
    <view class="section-title">当前配置</view>
    <view class="summary-list">
      <view class="summary-item">
        <text class="summary-label">流派</text>
        <text class="summary-value">{{currentSchool.schoolName || '未选择'}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">轴</text>
        <text class="summary-value">{{currentAxis ? currentAxis.axisName : '无'}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">目标</text>
        <text class="summary-value">{{currentTarget.targetName || '未选择'}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">主属性</text>
        <text class="summary-value">{{currentSchool.mainElement || '无'}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">固定心法</text>
        <text class="summary-value">{{currentSchool.fixedMentality || '无'}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">已选心法</text>
        <text class="summary-value">{{selectedMentalitiesText}}</text>
      </view>
    </view>
  </view>

  <!-- 核心选择 -->
  <view class="card">
    <view class="section-title">核心选择</view>

    <picker mode="selector" range="{{schoolOptions}}" value="{{schoolIndex}}" bindchange="handleSchoolChange">
      <view class="picker-row">
        <text class="picker-label">流派</text>
        <text class="picker-value">{{schoolOptions[schoolIndex] || '请选择流派'}}</text>
      </view>
    </picker>

    <view class="form-item">
      <text class="label">选择轴</text>
      <picker
        mode="selector"
        range="{{currentAxisList}}"
        range-key="axisName"
        value="{{axisIndex}}"
        bindchange="handleAxisChange"
      >
        <view class="picker">
          {{currentAxis ? currentAxis.axisName : '当前流派暂无轴'}}
        </view>
      </picker>
    </view>

    <picker mode="selector" range="{{targetOptions}}" value="{{targetIndex}}" bindchange="handleTargetChange">
      <view class="picker-row no-border">
        <text class="picker-label">目标</text>
        <text class="picker-value">{{targetOptions[targetIndex] || '请选择目标'}}</text>
      </view>
    </picker>
    <picker mode="selector" range="{{setOptions}}" value="{{setIndex}}" bindchange="handleSetChange">
      <view class="picker-row no-border">
        <text class="picker-label">套装</text>
        <text class="picker-value">{{selectedSet || '无'}}</text>
      </view>
    </picker>
    <picker mode="selector" range="{{tiangongOptions}}" value="{{tiangongIndex}}" bindchange="handleTiangongChange">
      <view class="picker-row">
        <text class="picker-label">天工</text>
        <text class="picker-value">{{tiangongOptions[tiangongIndex] || '无'}}</text>
      </view>
    </picker>

    <picker mode="selector" range="{{foodOptions}}" value="{{foodIndex}}" bindchange="handleFoodChange">
      <view class="picker-row no-border">
        <text class="picker-label">食物</text>
        <text class="picker-value">{{foodOptions[foodIndex] || '无'}}</text>
      </view>
    </picker>
  </view>

  <!-- 心法选择 -->
  <view class="card">
    <view class="section-title">心法选择</view>
    <view class="mentality-grid">
      <block wx:for="{{mentalityDisplayList}}" wx:for-item="mental" wx:for-index="index" wx:key="index">
        <view
          class="mentality-item {{mental.selected ? 'is-selected' : (mental.disabled ? 'is-disabled' : 'is-unselected')}}"
          data-name="{{mental.name}}"
          bindtap="handleToggleMentality"
        >
          <text class="mentality-text">{{mental.name}}</text>
          <text class="mentality-check" wx:if="{{mental.selected}}">已选</text>
          <text class="mentality-disabled-tip" wx:if="{{mental.disabled}}">已满</text>
        </view>
      </block>
    </view>
    <view class="tip">最多选择 3 个</view>
  </view>


  <!-- 毕业面板 -->
  <view class="card">
    <view class="section-title-row">
      <view class="section-title no-margin">毕业面板</view>
      <text class="section-action" bindtap="handleShowGrandPanel" wx:if="{{!ui.showGrandPanel}}">查看毕业面板</text>
      <text class="section-action" bindtap="toggleGrandPanel" wx:else>收起</text>
    </view>

    <view class="tip" wx:if="{{!currentGrandPanel}}">
      当前流派暂无毕业面板数据
    </view>

    <view wx:if="{{ui.showGrandPanel && currentGrandPanel}}">
      <view class="group-title">基础面板</view>
      <view class="grand-panel-mode-switch" wx:if="{{grandPanelModeOptions.length > 1}}">
        <view
          wx:for="{{grandPanelModeOptions}}"
          wx:key="mode"
          class="grand-panel-mode-item {{item.active ? 'is-active' : ''}}"
          data-mode="{{item.mode}}"
          bindtap="handleGrandPanelModeChange"
        >
          {{item.label}}
        </view>
      </view>
      <view class="summary-list">
        <view class="summary-item">
          <text class="summary-label">流派名称</text>
          <text class="summary-value">{{currentGrandPanelVariant.schoolName || currentGrandPanel.schoolName || '—'}}</text>
        </view>
        <view class="gp-outer-attack-card" wx:if="{{grandPanelMode !== 'outerMin'}}">
          <view class="gp-outer-attack-item">
            <text class="gp-outer-attack-label">小外</text>
            <text class="gp-outer-attack-value">{{currentGrandPanelVariant.attackOuterMin || '—'}}</text>
          </view>
          <view class="gp-outer-attack-divider"></view>
          <view class="gp-outer-attack-item">
            <text class="gp-outer-attack-label">大外</text>
            <text class="gp-outer-attack-value">{{currentGrandPanelVariant.attackOuterMax || '—'}}</text>
          </view>
        </view>
        <view class="gp-outer-attack-card gp-outer-attack-card-single" wx:else>
          <view class="gp-outer-attack-item">
            <text class="gp-outer-attack-label">固定外功</text>
            <text class="gp-outer-attack-value">{{currentGrandPanelVariant.attackOuterMin || '—'}}</text>
          </view>
        </view>
        <view class="summary-item">
          <text class="summary-label">外功穿透</text>
          <text class="summary-value">{{currentGrandPanelVariant.armorPenetration || '—'}}</text>
        </view>
      </view>

      <view class="group-title">四属性</view>
      <view class="summary-list">
        <view class="gp-element-block">
  <view class="gp-element-title">鸣金</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">最小鸣金</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.mingjinMin || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">最大鸣金</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.mingjinMax || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">鸣金穿透</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.mingjinPenetration || '—'}}</text>
    </view>
  </view>
</view>

<view class="gp-element-block">
  <view class="gp-element-title">裂石</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">最小裂石</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.lieshiMin || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">最大裂石</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.lieshiMax || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">裂石穿透</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.lieshiPenetration || '—'}}</text>
    </view>
  </view>
</view>

<view class="gp-element-block">
  <view class="gp-element-title">牵丝</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">最小牵丝</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.qiansiMin || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">最大牵丝</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.qiansiMax || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">牵丝穿透</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.qiansiPenetration || '—'}}</text>
    </view>
  </view>
</view>

<view class="gp-element-block">
  <view class="gp-element-title">破竹</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">最小破竹</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.pozhuMin || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">最大破竹</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.pozhuMax || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">破竹穿透</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.pozhuPenetration || '—'}}</text>
    </view>
  </view>
</view>
</view>
<view class="gp-element-block">
  <view class="gp-element-title">三率</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">精准率</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.accuracyRate || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">会心率</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.criticalRate || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">会意率</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.criticalDamageRate || '—'}}</text>
    </view>
  </view>
  <view class="gp-element-row" style="margin-top: 16rpx;">
    <view class="gp-element-item">
      <text class="gp-element-label">直接会心率</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.directCriticalRate || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">直接会意率</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.directCriticalDamageRate || '—'}}</text>
    </view>
    <view class="gp-element-item"></view>
  </view>
</view>

<view class="gp-element-block">
  <view class="gp-element-title">伤害加成</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">外功伤害</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.damageBonusOuter || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">属攻伤害</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.damageBonusElement || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">会心伤害</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.criticalBonus || '—'}}</text>
    </view>
  </view>
  <view class="gp-element-row" style="margin-top: 16rpx;">
    <view class="gp-element-item">
      <text class="gp-element-label">会意伤害</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.criticalDamageBonus || '—'}}</text>
    </view>
    <view class="gp-element-item"></view>
    <view class="gp-element-item"></view>
  </view>
</view>

<view class="gp-element-block">
  <view class="gp-element-title">额外增伤</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">全部武学增效</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.allMartialBonus || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">首领增伤</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.bossBonus || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">单体控制增伤</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.singleControlBonus || '—'}}</text>
    </view>
  </view>
  <view class="gp-element-row" style="margin-top: 16rpx;">
    <view class="gp-element-item">
      <text class="gp-element-label">单体爆发增伤</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.singleBurstBonus || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">群体伤害增伤</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.groupDamageBonus || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">群体异常增伤</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.groupAbnormalBonus || '—'}}</text>
    </view>
  </view>
</view>

      <view class="gp-element-block">
  <view class="gp-element-title">武学增效</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">增效1</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.martialBoost1 || currentGrandPanelVariant.weaponBoost1 || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">增效2</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.martialBoost2 || currentGrandPanelVariant.weaponBoost2 || '—'}}</text>
    </view>
    <view class="gp-element-item"></view>
  </view>
</view>

<view class="gp-element-block">
  <view class="gp-element-title">定音</view>
  <view class="gp-element-row">
    <view class="gp-element-item">
      <text class="gp-element-label">定音1</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.noteValue1 || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">定音2</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.noteValue2 || '—'}}</text>
    </view>
    <view class="gp-element-item">
      <text class="gp-element-label">定音3</text>
      <text class="gp-element-value">{{currentGrandPanelVariant.noteValue3 || '—'}}</text>
    </view>
  </view>
</view>

      <view class="grand-panel-action">
        <button class="grand-panel-btn" bindtap="handleApplyGrandPanel">自动填入</button>
      </view>
    </view>
  </view>

  <!-- 核心输入 -->
  <view class="card">
    <view class="section-title">核心输入</view>

    <view class="group-title">外功面板</view>
    <view class="form-item">
      <text class="label">最小外功攻击</text>
      <input class="input" type="digit" value="{{form.physicalMinAttack}}" data-field="physicalMinAttack" bindinput="handleInput" placeholder="请输入" />
    </view>
    <view class="form-item">
      <text class="label">最大外功攻击</text>
      <input class="input" type="digit" value="{{form.physicalMaxAttack}}" data-field="physicalMaxAttack" bindinput="handleInput" placeholder="请输入" />
    </view>
    <view class="form-item">
      <text class="label">外功穿透</text>
      <input class="input" type="digit" value="{{form.physicalPenetration}}" data-field="physicalPenetration" bindinput="handleInput" placeholder="请输入" />
    </view>
    <view class="form-item">
      <text class="label">外功伤害加成（%）</text>
      <input class="input" type="digit" value="{{form.physicalBonus}}" data-field="physicalBonus" bindinput="handleInput" placeholder="请输入" />
    </view>

    <view class="group-title">主属性面板</view>

    <block wx:if="{{currentSchool.mainElement === '鸣金'}}">
      <view class="form-item">
        <text class="label">最小鸣金攻击</text>
        <input class="input" type="digit" value="{{form.mingjinMin}}" data-field="mingjinMin" bindinput="handleInput" placeholder="请输入" />
      </view>
      <view class="form-item">
        <text class="label">最大鸣金攻击</text>
        <input class="input" type="digit" value="{{form.mingjinMax}}" data-field="mingjinMax" bindinput="handleInput" placeholder="请输入" />
      </view>
      <view class="form-item">
        <text class="label">鸣金穿透</text>
        <input class="input" type="digit" value="{{form.mingjinPen}}" data-field="mingjinPen" bindinput="handleInput" placeholder="请输入" />
      </view>
    </block>

    <block wx:elif="{{currentSchool.mainElement === '牵丝'}}">
      <view class="form-item">
        <text class="label">最小牵丝攻击</text>
        <input class="input" type="digit" value="{{form.qiansiMin}}" data-field="qiansiMin" bindinput="handleInput" placeholder="请输入" />
      </view>
      <view class="form-item">
        <text class="label">最大牵丝攻击</text>
        <input class="input" type="digit" value="{{form.qiansiMax}}" data-field="qiansiMax" bindinput="handleInput" placeholder="请输入" />
      </view>
      <view class="form-item">
        <text class="label">牵丝穿透</text>
        <input class="input" type="digit" value="{{form.qiansiPen}}" data-field="qiansiPen" bindinput="handleInput" placeholder="请输入" />
      </view>
    </block>

    <block wx:elif="{{currentSchool.mainElement === '裂石'}}">
      <view class="form-item">
        <text class="label">最小裂石攻击</text>
        <input class="input" type="digit" value="{{form.lieshiMin}}" data-field="lieshiMin" bindinput="handleInput" placeholder="请输入" />
      </view>
      <view class="form-item">
        <text class="label">最大裂石攻击</text>
        <input class="input" type="digit" value="{{form.lieshiMax}}" data-field="lieshiMax" bindinput="handleInput" placeholder="请输入" />
      </view>
      <view class="form-item">
        <text class="label">裂石穿透</text>
        <input class="input" type="digit" value="{{form.lieshiPen}}" data-field="lieshiPen" bindinput="handleInput" placeholder="请输入" />
      </view>
    </block>

    <block wx:elif="{{currentSchool.mainElement === '破竹'}}">
      <view class="form-item">
        <text class="label">最小破竹攻击</text>
        <input class="input" type="digit" value="{{form.pozhuMin}}" data-field="pozhuMin" bindinput="handleInput" placeholder="请输入" />
      </view>
      <view class="form-item">
        <text class="label">最大破竹攻击</text>
        <input class="input" type="digit" value="{{form.pozhuMax}}" data-field="pozhuMax" bindinput="handleInput" placeholder="请输入" />
      </view>
      <view class="form-item">
        <text class="label">破竹穿透</text>
        <input class="input" type="digit" value="{{form.pozhuPen}}" data-field="pozhuPen" bindinput="handleInput" placeholder="请输入" />
      </view>
    </block>

    <view class="form-item">
      <text class="label">属攻伤害加成（%）</text>
      <input class="input" type="digit" value="{{form.elementBonus}}" data-field="elementBonus" bindinput="handleInput" placeholder="请输入" />
    </view>

    <!-- 其他属性输入 -->
    <view class="section-title-row">
      <view class="group-title">其他属性输入</view>
      <text class="section-action" bindtap="toggleAllElements">
        {{ui.showAllElements ? '收起' : '展开'}}
      </text>
    </view>

    <view wx:if="{{ui.showAllElements}}">
      <block wx:if="{{currentSchool.mainElement !== '鸣金'}}">
        <view class="sub-title">鸣金</view>
